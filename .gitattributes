# Normalize line endings: the repo ALWAYS stores LF, regardless of the dev's OS
* text=auto eol=lf

# Files that MUST be LF (scripts and configs that run on Linux/containers)
*.sh      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
Dockerfile text eol=lf
*.go      text eol=lf
*.cs      text eol=lf
*.py      text eol=lf

# Binary files: git must not touch them
*.png     binary
*.jpg     binary
*.ico     binary